# --- Supabase (Aurora project: vmpzkytxdruwbdftxtnm) ---
SUPABASE_URL=https://vmpzkytxdruwbdftxtnm.supabase.co

# The backend talks to Supabase over the REST API via supabase-py.
# Use the SERVICE_ROLE (secret) key so the backend can bypass RLS on
# hackathon_items. Find it in Supabase -> Project Settings -> API keys
# (a legacy `service_role` JWT, or a modern `sb_secret_...` key).
# NEVER expose this key in the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service_role-or-sb_secret-key

# Publishable/anon key (safe for browsers; subject to RLS). Optional here.
SUPABASE_ANON_KEY=sb_publishable_AHtGFifU6XjtvCyhDbYEvw_pyegK3YR

# Origins allowed to call the API (comma-separated). The Vite dev server default:
CORS_ORIGINS=http://localhost:5173

# Table prefix for this project inside the shared public schema.
TABLE_PREFIX=hackathon_

# --- Anthropic (Beacon sales-angle generation; optional) ---
# Without a key, Beacon falls back to deterministic persona/signal templates.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Gamma (Beacon deck generation via the public Generate API) ---
# Needed for the "Gamma deck" link to generate a real deck. Theme id defaults
# to the hand-built Polar theme (see knowledge/.../GAMMA_THEME.md).
GAMMA_API_KEY=
GAMMA_THEME_ID=41qx0nu4jsi7txp

# --- Snowflake (JWT key-pair auth; ported from ../aurora) ---
# PEM private key may be a single line with literal \n between the lines.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# --- HubSpot (private app; Bearer auth against api.hubapi.com) ---
# Create a private app in HubSpot -> Settings -> Integrations -> Private Apps.
# The access token needs the crm.objects.companies/contacts read+write scopes
# (and crm.objects.tasks for draft-email tasks). Keep the real value in .env only.
HUBSPOT_ACCESS_TOKEN=pat-xxxx-your-private-app-token
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret